{
  "expo": {
    "name": "駅で起こして",
    "slug": "station-alarm",
    "version": "1.0.1",
    "runtimeVersion": "1.1.2",
    "updates": {
      "url": "https://u.expo.dev/415d7682-2fe5-4bea-8aeb-766a559bcd2c"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "toshihide.matsuda.stationalarm",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "電車内での寝過ごし防止のため、バックグラウンドで位置情報を取得します。",
        "NSLocationWhenInUseUsageDescription": "周辺の駅を表示するため、現在地を取得します。",
        "NSLocationAlwaysUsageDescription": "電車内での寝過ごし防止のため、バックグラウンドで位置情報を取得します。",
        "NSMusicLibraryUsageDescription": "アラーム音としてお気に入りの音楽を使用するため、音楽ライブラリへのアクセスが必要です。",
        "UIBackgroundModes": [
          "location",
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "toshihide.matsuda.stationalarm",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "電車内での寝過ごし防止のため、バックグラウンドで位置情報を取得します。",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "26.0"
          }
        }
      ]
    ],
    "scheme": "stationalarm",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "415d7682-2fe5-4bea-8aeb-766a559bcd2c"
      }
    }
  }
}
